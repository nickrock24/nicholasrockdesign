# Airtable Personal Access Token, scoped to data.records:read, data.records:write,
# schema.bases:read, restricted to this one base.
AIRTABLE_API_KEY=

AIRTABLE_BASE_ID=

# Auto-injected by Vercel when a Blob store is connected to this project.
# Only needed locally if you're running the migration/sync scripts.
BLOB_READ_WRITE_TOKEN=

# Shared secret checked by app/api/revalidate/route.ts. Generate a random
# value and put the same one in each Airtable Automation's webhook config.
REVALIDATE_SECRET=

# Public site URL, used in sitemap.xml/robots.txt.
NEXT_PUBLIC_SITE_URL=https://nicholasrock.design
